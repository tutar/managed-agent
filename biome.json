{
	"$schema": "https://biomejs.dev/schemas/2.3.5/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"noLabelWithoutControl": "off",
				"noStaticElementInteractions": "off",
				"noSvgWithoutTitle": "off",
				"useButtonType": "off",
				"useKeyWithClickEvents": "off"
			},
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useNodejsImportProtocol": "off"
			},
			"suspicious": {
				"noArrayIndexKey": "off",
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off",
				"noEmptyInterface": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"files": {
		"includes": [
			"apps/*/src/**/*.ts",
			"apps/*/src/**/*.tsx",
			"apps/*/test/**/*.ts",
			"apps/*/test/**/*.tsx",
			"apps/web-ui/src/**/*.ts",
			"apps/web-ui/src/**/*.tsx",
			"!**/node_modules/**/*",
			"!**/models.generated.ts",
			"!apps/web-ui/src/index.css",
			"!!**/node_modules"
		]
	}
}
