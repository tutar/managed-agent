{
  "name": "@managed-agent/harness-worker",
  "description": "Managed Agent harness worker and runtime adapters.",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "start": "node --import tsx src/server.ts",
    "dev": "node --watch --import tsx src/server.ts",
    "lint": "biome check src",
    "format": "biome format --write src",
    "typecheck": "tsc -p tsconfig.json",
    "test:unit": "node --import tsx --test test/*.test.ts",
    "check": "npm run lint && npm run typecheck"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  }
}
