{
  "name": "@managed-agent/harness",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/executor.js",
  "types": "./dist/executor.d.ts",
  "exports": {
    ".": "./dist/executor.js"
  },
  "bin": {
    "harness": "./dist/cli.js"
  },
  "scripts": {
    "start": "npm run dev:all",
    "build": "tsc",
